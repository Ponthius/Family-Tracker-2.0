{
    "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "strict": true,
    "lib": ["ESNext", "DOM", "ES2021"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "rootDir": "./src"
   },
    "include": ["src/**/*"]
     }
