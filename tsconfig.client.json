{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noEmit": false,
    "outDir": "./public/client",
  },
  "include": ["src/client/**/*"],
  "exclude": ["node_modules"]
}
